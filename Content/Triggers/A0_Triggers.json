{
    "sceneId": "SCN_A0_INITIATION",
    "triggers": [
        {
            "triggerId": "TRG_PROLOGUE_START",
            "type": "scene_enter",
            "condition": "phase == Awakening",
            "actions": [
                {
                    "type": "set_objective",
                    "objectiveId": "UI_OBJ_EXIT_CAPSULE"
                },
                {
                    "type": "play_dialogue",
                    "dialogueId": null
                },
                {
                    "type": "journal_entry",
                    "text": "Пробуждение в капсуле. Системы инициализируются."
                }
            ]
        },
        {
            "triggerId": "TRG_PHASE_IDENTIFICATION",
            "type": "phase_change",
            "condition": "phase == Identification",
            "actions": [
                {
                    "type": "set_objective",
                    "objectiveId": "UI_OBJ_BIOMETRIC"
                },
                {
                    "type": "journal_entry",
                    "text": "Капсула открыта. Необходимо пройти идентификацию."
                }
            ]
        },
        {
            "triggerId": "TRG_PHASE_PROVISIONING",
            "type": "phase_change",
            "condition": "phase == Provisioning",
            "actions": [
                {
                    "type": "set_objective",
                    "objectiveId": "UI_OBJ_LOGISTICS"
                },
                {
                    "type": "play_dialogue",
                    "dialogueId": "DIA_BIO_CONFIRM"
                },
                {
                    "type": "journal_entry",
                    "text": "Идентификация подтверждена. Получить снаряжение."
                }
            ]
        },
        {
            "triggerId": "TRG_PHASE_DRONE",
            "type": "phase_change",
            "condition": "phase == DroneContact",
            "actions": [
                {
                    "type": "set_objective",
                    "objectiveId": "UI_OBJ_DRONE"
                },
                {
                    "type": "play_dialogue",
                    "dialogueId": "DIA_SUPPLY_GRANTED"
                },
                {
                    "type": "journal_entry",
                    "text": "Снаряжение получено. Активировать дрон."
                }
            ]
        },
        {
            "triggerId": "TRG_PHASE_ACTIVATION",
            "type": "phase_change",
            "condition": "phase == Activation",
            "actions": [
                {
                    "type": "set_objective",
                    "objectiveId": "UI_OBJ_CORE"
                },
                {
                    "type": "journal_entry",
                    "text": "Дрон активирован. Обратиться к C.O.R.E."
                }
            ]
        },
        {
            "triggerId": "TRG_PHASE_OPERATION_ACCESS",
            "type": "phase_change",
            "condition": "phase == OperationAccess",
            "actions": [
                {
                    "type": "set_objective",
                    "objectiveId": "UI_OBJ_EXPLORE"
                },
                {
                    "type": "play_dialogue",
                    "dialogueId": "DIA_CORE_ACTIVATION"
                },
                {
                    "type": "journal_entry",
                    "text": "C.O.R.E. активирован. Доступ к операциям открыт."
                }
            ]
        },
        {
            "triggerId": "TRG_GALLERY_LOOK",
            "type": "object_interact",
            "condition": "objectId == OBJ_GALLERY_OVERLOOK",
            "actions": [
                {
                    "type": "play_dialogue",
                    "dialogueId": "DIA_GALLERY_OVERLOOK"
                },
                {
                    "type": "camera_event",
                    "cameraId": "CAM_SHAFT_LOOK_DOWN"
                },
                {
                    "type": "journal_entry",
                    "text": "Обзорная галерея. Хард-Архив виден внизу."
                }
            ]
        },
        {
            "triggerId": "TRG_ARCHIVE_BLOCKED",
            "type": "object_interact",
            "condition": "objectId == OBJ_ARCHIVE_GATE",
            "actions": [
                {
                    "type": "play_dialogue",
                    "dialogueId": "DIA_ARCHIVE_LOCKED"
                },
                {
                    "type": "journal_entry",
                    "text": "Вход в Хард-Архив заблокирован до завершения первой операции."
                }
            ]
        },
        {
            "triggerId": "TRG_PROLOGUE_COMPLETE",
            "type": "all_objectives_done",
            "condition": "phase == OperationAccess && visited(OBJ_OP_TERMINAL) && visited(OBJ_GALLERY_OVERLOOK)",
            "actions": [
                {
                    "type": "set_objective",
                    "objectiveId": "UI_OBJ_PROLOGUE_DONE"
                },
                {
                    "type": "unlock_mission",
                    "missionId": "MISSION_PROTOCOL_ZERO"
                },
                {
                    "type": "journal_entry",
                    "text": "Пролог завершён. Протокол Ноль разблокирован."
                }
            ]
        }
    ]
}
