{
    "sceneId": "SCN_A0_INITIATION",
    "dialogues": [
        {
            "dialogueId": "DIA_DRONE_GREETING",
            "speaker": "NPC_ARCHIVE_DRONE",
            "speakerDisplayName": "Архивный дрон",
            "lines": [
                {
                    "lineId": "DIA_DRONE_GREETING_01",
                    "text": "Инициализация дрона... Серийный номер подтверждён.",
                    "delay": 1.5
                },
                {
                    "lineId": "DIA_DRONE_GREETING_02",
                    "text": "Оператор Арквейн. Протокол пробуждения выполнен штатно.",
                    "delay": 2.0
                },
                {
                    "lineId": "DIA_DRONE_GREETING_03",
                    "text": "Ваш допуск: начальный. Рекомендация: обратитесь к C.O.R.E. для активации систем.",
                    "delay": 2.5
                }
            ],
            "options": []
        },
        {
            "dialogueId": "DIA_CORE_ACTIVATION",
            "speaker": "SYSTEM_CORE",
            "speakerDisplayName": "C.O.R.E.",
            "lines": [
                {
                    "lineId": "DIA_CORE_ACTIVATION_01",
                    "text": "C.O.R.E. — Центральная Операционная Регистрационная Единица.",
                    "delay": 2.0
                },
                {
                    "lineId": "DIA_CORE_ACTIVATION_02",
                    "text": "Оператор идентифицирован. Статус Архива: нестабилен.",
                    "delay": 2.0
                },
                {
                    "lineId": "DIA_CORE_ACTIVATION_03",
                    "text": "Терминал операций активирован. Первая операция ожидает назначения.",
                    "delay": 2.0
                },
                {
                    "lineId": "DIA_CORE_ACTIVATION_04",
                    "text": "Обзорная галерея открыта. Рекомендация: осмотрите Хард-Архив перед началом.",
                    "delay": 2.5
                }
            ],
            "options": []
        },
        {
            "dialogueId": "DIA_BIO_CONFIRM",
            "speaker": "SYSTEM",
            "speakerDisplayName": "Система",
            "lines": [
                {
                    "lineId": "DIA_BIO_CONFIRM_01",
                    "text": "Сканирование... Идентификация подтверждена.",
                    "delay": 1.5
                },
                {
                    "lineId": "DIA_BIO_CONFIRM_02",
                    "text": "Оператор: Алан Арквейн. Допуск: начальный. Добро пожаловать.",
                    "delay": 2.0
                }
            ],
            "options": []
        },
        {
            "dialogueId": "DIA_SUPPLY_GRANTED",
            "speaker": "SYSTEM",
            "speakerDisplayName": "Логистика",
            "lines": [
                {
                    "lineId": "DIA_SUPPLY_GRANTED_01",
                    "text": "Комплект снаряжения подготовлен: жетон, сканер, рацион.",
                    "delay": 1.5
                },
                {
                    "lineId": "DIA_SUPPLY_GRANTED_02",
                    "text": "Заберите предметы и проследуйте к стыковочной нише дрона.",
                    "delay": 2.0
                }
            ],
            "options": []
        },
        {
            "dialogueId": "DIA_ARCHIVE_LOCKED",
            "speaker": "SYSTEM",
            "speakerDisplayName": "Система безопасности",
            "lines": [
                {
                    "lineId": "DIA_ARCHIVE_LOCKED_01",
                    "text": "Врата Хард-Архива заблокированы.",
                    "delay": 1.5
                },
                {
                    "lineId": "DIA_ARCHIVE_LOCKED_02",
                    "text": "Для получения доступа необходимо завершить первую назначенную операцию.",
                    "delay": 2.0
                }
            ],
            "options": []
        },
        {
            "dialogueId": "DIA_GALLERY_OVERLOOK",
            "speaker": "NARRATOR",
            "speakerDisplayName": "",
            "lines": [
                {
                    "lineId": "DIA_GALLERY_OVERLOOK_01",
                    "text": "Перед тобой — шахта Хард-Архива. Бесконечные этажи уходят вниз.",
                    "delay": 2.0
                },
                {
                    "lineId": "DIA_GALLERY_OVERLOOK_02",
                    "text": "Полки. Тома. Коридоры. Лестницы. Всё это — каталог возможных исходов.",
                    "delay": 2.5
                },
                {
                    "lineId": "DIA_GALLERY_OVERLOOK_03",
                    "text": "Где-то внизу ждёт первая операция. Протокол Ноль.",
                    "delay": 2.0
                }
            ],
            "options": []
        }
    ]
}
