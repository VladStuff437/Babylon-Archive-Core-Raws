{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Session023InventorySchema",
    "type": "object",
    "properties": {
        "ownerId": {
            "type": "string"
        },
        "capacity": {
            "type": "integer",
            "minimum": 1
        },
        "slots": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "itemId": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "quantity": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "maxStack": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "category": {
                        "type": "string"
                    }
                },
                "required": [
                    "itemId",
                    "name"
                ]
            }
        }
    },
    "required": [
        "ownerId",
        "capacity",
        "slots"
    ]
}
