{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session029PerceptionSchema",
  "type": "object",
  "properties": {
    "agentId": {
      "type": "string"
    },
    "detectionRadius": {
      "type": "number",
      "minimum": 0
    },
    "alertThreshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "visibleTargets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "primaryTargetId": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "agentId",
    "detectionRadius",
    "alertThreshold",
    "visibleTargets"
  ]
}
