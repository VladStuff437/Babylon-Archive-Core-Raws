{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Session030EnemyStateMachineSchema",
  "type": "object",
  "properties": {
    "agentId": {
      "type": "string"
    },
    "currentState": {
      "type": "string"
    },
    "aggression": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "leashDistance": {
      "type": "number",
      "minimum": 0
    },
    "lastSeenTargetTicks": {
      "type": "integer",
      "minimum": 0
    },
    "primaryTargetId": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "agentId",
    "currentState",
    "aggression",
    "leashDistance",
    "lastSeenTargetTicks"
  ]
}
