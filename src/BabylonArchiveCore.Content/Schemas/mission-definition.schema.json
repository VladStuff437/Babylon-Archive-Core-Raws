{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MissionDefinitionSchema",
  "type": "object",
  "properties": {
    "missionId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "startNodeId": {
      "type": "string"
    },
    "contractVersion": {
      "type": "integer",
      "minimum": 37
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "nodeId": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "isTerminal": {
            "type": "boolean"
          },
          "isCheckpoint": {
            "type": "boolean"
          },
          "transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "targetNodeId": {
                  "type": "string"
                },
                "priority": {
                  "type": "integer"
                },
                "conditionKey": {
                  "type": ["string", "null"]
                },
                "isFallback": {
                  "type": "boolean"
                }
              },
              "required": [
                "targetNodeId",
                "priority",
                "isFallback"
              ]
            }
          }
        },
        "required": [
          "nodeId",
          "description",
          "isTerminal",
          "isCheckpoint",
          "transitions"
        ]
      }
    }
  },
  "required": [
    "missionId",
    "title",
    "startNodeId",
    "contractVersion",
    "nodes"
  ]
}
